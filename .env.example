# ============================================================
# JARVIS AI — ENVIRONMENT CONFIG
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ----- AI PROVIDER -----
# Options: "ollama" | "groq" | "anthropic" | "proxy"
# Local development defaults to "ollama".
# Production builds default to "proxy" so browser users do not receive API keys.
REACT_APP_AI_PROVIDER=ollama

# ----- OLLAMA (local, free) -----
# Keep this as-is. Ollama runs on your computer at this address.
REACT_APP_OLLAMA_URL=http://localhost:11434
REACT_APP_OLLAMA_MODEL=llama3.2

# ----- GROQ (free cloud — for public website) -----
# Sign up free at console.groq.com, paste your key here
# for local-only testing. Use GROQ_KEY on Vercel for public deploys.
REACT_APP_GROQ_KEY=your_groq_key_here
REACT_APP_GROQ_MODEL=llama3-70b-8192

# ----- ANTHROPIC (paid cloud — best quality) -----
# Sign up at console.anthropic.com
REACT_APP_ANTHROPIC_KEY=your_anthropic_key_here

# ----- VERCEL SERVERLESS PROXY -----
# Add these in the Vercel dashboard, not in the React client env:
# AI_PROVIDER=groq
# GROQ_KEY=your_groq_key_here
# GROQ_MODEL=llama3-70b-8192
# ANTHROPIC_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
