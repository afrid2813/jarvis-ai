# ============================================================
# JARVIS AI — ENVIRONMENT CONFIG
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ----- AI PROVIDER -----
# Options: "proxy"
# All AI traffic must go through /api/chat so API keys never ship to browsers.
REACT_APP_AI_PROVIDER=proxy

# ----- API SECURITY -----
ALLOWED_ORIGIN=http://localhost:3000
# Optional: allow Vercel preview deployment origins ending in .vercel.app.
# Keep false for stricter production allowlisting.
ALLOW_VERCEL_PREVIEWS=false

# ----- SECRET KEYS -----
# Never add Groq/Anthropic keys as REACT_APP_* values.
# Client-side REACT_APP_* variables are baked into the browser bundle.
# Put provider keys only in server environment variables.
# For local dev, .env.local is read by the local proxy and must never be committed.
# For production, set them in the Vercel dashboard.

# ----- VERCEL SERVERLESS PROXY -----
# Add these in the Vercel dashboard for production, or .env.local for local dev.
# Do not prefix secret keys with REACT_APP_.
# ALLOWED_ORIGIN=https://your-domain.vercel.app
# ALLOW_VERCEL_PREVIEWS=false
# AI_PROVIDER=groq
# GROQ_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# NEWS_KEY=your_newsapi_key_here
